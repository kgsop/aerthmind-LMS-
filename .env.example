# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your Firebase project values.
# For Netlify: add these same keys in Site → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase project config (from Firebase Console → Project Settings → Your apps)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456
